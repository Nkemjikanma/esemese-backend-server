APP_ENV=production
PORT=8000

# Database - admin (superuser, runs migrations)
DB_ADMIN_USERNAME=esemese_admin
DB_ADMIN_PASSWORD=CHANGE_ME

# Database - app (restricted, runtime only — DML, no DDL)
DB_USERNAME=esemese_app
DB_PASSWORD=CHANGE_ME

DB_HOST=postgres
DB_PORT=5432
DB_NAME=esemese_db
DB_REQUIRE_SSL=false

# Used by sqlx-cli for compile-time checks and migrations
DATABASE_URL=postgres://esemese_admin:CHANGE_ME@localhost:5432/esemese_db

# App admin login
ADMIN_USERNAME=CHANGE_ME
ADMIN_PASSWORD_HASH=CHANGE_ME

# JWT
JWT_SECRET=CHANGE_ME

# RustFS (S3-compatible object storage)
RUSTFS_ACCESS_KEY=CHANGE_ME
RUSTFS_SECRET_KEY=CHANGE_ME
